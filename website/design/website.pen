              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "81tdW",
                  "name": "Cards Row",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 20,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "oJD9I",
                      "name": "Left Card",
                      "width": 760,
                      "layout": "vertical",
                      "gap": 24,
                      "alignItems": "center",
                      "children": [
                        {
                          "id": "Qf4tP",
                          "type": "ref",
                          "ref": "69r4N",
                          "name": "GSQL Model",
                          "width": 760,
                          "height": "fit_content",
                          "flipX": false,
                          "flipY": false,
                          "x": 0,
                          "y": 0,
                          "descendants": {
                            "EaVOv": {
                              "height": 44
                            },
                            "V2U5E": {
                              "content": "GSQL Model",
                              "fill": "#3A3632"
                            },
                            "FBW20": {
                              "width": 704,
                              "fontSize": "$code_font_size",
                              "content": "table orders (\n  id BIGINT -- Primary key\n  user_id BIGINT\n  created_at DATETIME\n  status STRING -- One of 'Processing', 'Shipped', 'Complete', 'Cancelled', 'Returned'\n  amount FLOAT -- Amount paid by customer\n  cost FLOAT -- Cost of materials\n\n  join one users on user_id = users.id\n\n  revenue_recognized: status in ('Processing', 'Shipped', 'Complete')\n  revenue: sum(case when revenue_recognized then amount else 0 end)\n  cogs: sum(case when revenue_recognized then cost else 0 end)\n  profit: revenue - cogs\n  profit_margin: profit / revenue\n)\n\ntable users (\n  id BIGINT -- Primary key\n  email VARCHAR\n  country_code VARCHAR\n)"
                            }
                          }
                        },
                        {
                          "id": "OGFXf",
                          "type": "ref",
                          "ref": "69r4N",
                          "name": "GSQL Query",
                          "width": 760,
                          "height": "fit_content",
                          "flipX": false,
                          "flipY": false,
                          "x": 0,
                          "y": 526,
                          "descendants": {
                            "EaVOv": {
                              "height": 44
                            },
                            "V2U5E": {
                              "content": "GSQL Query",
                              "fill": "#3A3632"
                            },
                            "FBW20": {
                              "width": 704,
                              "fontSize": "$code_font_size",
                              "content": "select users.country_code, -- Join is implied via your model\n  profit_margin -- Invoke modeled measures \nfrom orders "
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "s2uIZ",
                      "name": "Arrow Column",
                      "width": 760,
                      "height": 36,
                      "layout": "vertical",
                      "justifyContent": "center",
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "D5pLk",
                          "name": "arrowIcon",
                          "width": 20,
                          "height": 20,
                          "iconFontName": "arrow-down",
                          "iconFontFamily": "lucide",
                          "fill": "#A8A29E"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "Npfe2",
                      "name": "Right Card",
                      "width": 760,
                      "height": 664,
                      "layout": "vertical",
                      "gap": 12,
                      "alignItems": "center",
                      "children": [
                        {
                          "id": "indL9",
                          "type": "ref",
                          "ref": "69r4N",
                          "name": "Compiled SQL",
                          "width": 760,
                          "height": "fit_content",
                          "descendants": {
                            "EaVOv": {
                              "height": 44
                            },
                            "V2U5E": {
                              "content": "Compiled SQL",
                              "fill": "#3A3632"
                            },
                            "FBW20": {
                              "content": "select users.country_code, \n  (sum(\n    case when status in ('Processing', 'Shipped', 'Complete') \n    then amount \n    else 0 end\n  ) \n  - \n  sum(\n    case when status in ('Processing', 'Shipped', 'Complete') \n    then cost \n    else 0 end\n  )) \n  / \n  sum(\n    case when status in ('Processing', 'Shipped', 'Complete') \n    then amount \n    else 0 end\n  ) as profit_margin\nfrom orders \nleft join users on orders.user_id = users.id \ngroup by 1 \norder by 2 desc",
                              "width": 704,
                              "fontSize": "$code_font_size"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
