            {
              "type": "frame",
              "id": "zemqy",
              "name": "SQL Comparison",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 20,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "U9PpI",
                  "name": "Cards Row",
                  "width": 1136,
                  "gap": 16,
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "s7lNg",
                      "name": "Left Card",
                      "width": 530,
                      "layout": "vertical",
                      "gap": 24,
                      "children": [
                        {
                          "id": "jojnP",
                          "type": "ref",
                          "ref": "69r4N",
                          "name": "GSQL Model",
                          "height": "fit_content",
                          "width": 530,
                          "flipX": false,
                          "flipY": false,
                          "x": 0,
                          "y": 0,
                          "descendants": {
                            "EaVOv": {
                              "height": 44
                            },
                            "V2U5E": {
                              "content": "GSQL Model",
                              "fill": "#3A3632"
                            },
                            "FBW20": {
                              "content": "table orders (\n  id BIGINT -- Primary key\n  user_id BIGINT\n  created_at DATETIME\n  status STRING -- One of 'Processing', 'Shipped', 'Complete', 'Cancelled', 'Returned'\n  amount FLOAT -- Amount paid by customer\n  cost FLOAT -- Cost of materials\n\n  join one users on user_id = users.id\n\n  revenue_recognized: status in ('Processing', 'Shipped', 'Complete')\n  revenue: sum(case when revenue_recognized then amount else 0 end)\n  cogs: sum(case when revenue_recognized then cost else 0 end)\n  profit: revenue - cogs\n  profit_margin: profit / revenue\n)\n\ntable users (\n  id BIGINT -- Primary key\n  email VARCHAR\n  country_code VARCHAR\n)",
                              "width": 474,
                              "fontSize": "$code_font_size"
                            }
                          }
                        },
                        {
                          "id": "mMzzA",
                          "type": "ref",
                          "ref": "69r4N",
                          "name": "GSQL",
                          "width": 530,
                          "height": "fit_content",
                          "flipX": false,
                          "flipY": false,
                          "x": 0,
                          "y": 583,
                          "descendants": {
                            "EaVOv": {
                              "height": 44
                            },
                            "V2U5E": {
                              "content": "GSQL Query",
                              "fill": "#3A3632"
                            },
                            "FBW20": {
                              "content": "select users.country_code, -- Join is implied via your model\n  profit_margin -- Invoke modeled measures \nfrom orders ",
                              "width": 474,
                              "fontSize": "$code_font_size"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "j039a",
                      "name": "Arrow Column",
                      "width": 44,
                      "height": "fill_container",
                      "layout": "vertical",
                      "justifyContent": "center",
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "GLSJr",
                          "name": "arrowIcon",
                          "width": 20,
                          "height": 20,
                          "iconFontName": "arrow-right",
                          "iconFontFamily": "lucide",
                          "fill": "#A8A29E"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "90iOB",
                      "name": "Right Card",
                      "width": 530,
                      "children": [
                        {
                          "id": "YaFw9",
                          "type": "ref",
                          "ref": "69r4N",
                          "name": "Compiled SQL",
                          "width": 530,
                          "height": "fit_content",
                          "flipX": false,
                          "flipY": false,
                          "x": 0,
                          "y": 0,
                          "descendants": {
                            "EaVOv": {
                              "height": 44
                            },
                            "V2U5E": {
                              "content": "Compiled SQL",
                              "fill": "#3A3632"
                            },
                            "FBW20": {
                              "content": "select users.country_code, \n  (sum(\n    case when status in ('Processing', 'Shipped', 'Complete') \n    then amount \n    else 0 end\n  ) \n  - \n  sum(\n    case when status in ('Processing', 'Shipped', 'Complete') \n    then cost \n    else 0 end\n  )) \n  / \n  sum(\n    case when status in ('Processing', 'Shipped', 'Complete') \n    then amount \n    else 0 end\n  ) as profit_margin\nfrom orders \nleft join users on orders.user_id = users.id \ngroup by 1 \n",
                              "width": 474,
                              "fontSize": "$code_font_size"
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
