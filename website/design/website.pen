              "fill": "#A8A29E",
              "textGrowth": "fixed-width",
              "width": 480,
              "content": "Graphene is currently in a closed access beta. \nWe work closely with our early customers to solve \nreal-world problems.",
              "lineHeight": 1.6,
              "textAlign": "center",
              "fontFamily": "Inter",
