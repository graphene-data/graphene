<section class="mt-20 sm:mt-[100px] lg:mt-[150px] pt-16 sm:pt-20 lg:pt-[120px] pb-24 sm:pb-32 lg:pb-[150px] relative overflow-hidden flex items-center">
  <!-- Cross-hatch background with radial fade -->
  <div class="absolute inset-0 pointer-events-none" style="
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 10px, rgba(12, 10, 9, 0.08) 10px, rgba(12, 10, 9, 0.08) 11px),
      repeating-linear-gradient(90deg, transparent, transparent 10px, rgba(12, 10, 9, 0.08) 10px, rgba(12, 10, 9, 0.08) 11px);
    mask-image: radial-gradient(ellipse at center, black 0%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, black 20%, transparent 70%);
  "></div>

  <div class="max-w-[1312px] w-full mx-auto px-4 sm:px-8 lg:px-[52px] flex flex-col items-center gap-6 lg:gap-8 relative z-10">
    <h2 class="font-serif text-[32px] sm:text-[38px] lg:text-[44px] text-primary-dark tracking-[-0.75px] sm:tracking-[-0.875px] lg:tracking-[-1px] leading-[1] text-center">Try it on your data</h2>
    <p class="text-base sm:text-[16px] lg:text-[17px] text-body text-center leading-[1.5] max-w-[550px]">
        Graphene is currently in a closed access beta. We work closely with our early customers to solve real-world problems.
    </p>
    <a href="/contact-us" class="bg-primary-dark text-bg text-sm font-medium rounded-lg px-6 py-2.5 hover:opacity-90 transition-opacity">
      Join the waitlist
    </a>
  </div>
</section>
