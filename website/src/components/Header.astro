---
import logoSrc from '../assets/logo_transparent.png';
---

<header class="border-b border-border/20">
  <div class="max-w-[1312px] mx-auto px-[52px] h-[72px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <img src={logoSrc.src} alt="Graphene" width="28" height="28" />
      <span class="font-logo text-xl font-bold tracking-[-0.5px] text-primary-dark">Graphene</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/about" class="text-sm font-medium text-body hover:text-primary-dark transition-colors">About</a>
      <a href="https://github.com/graphene-data/graphene" target="_blank" rel="noopener" class="text-sm font-medium text-body hover:text-primary-dark transition-colors">GitHub</a>
      <button class="bg-primary-dark text-bg text-sm font-medium rounded-lg px-6 py-2.5 hover:opacity-90 transition-opacity cursor-pointer">Join waitlist</button>
    </nav>

    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer bg-transparent border-none" aria-label="Toggle menu">
      <span class="block w-5 h-0.5 bg-primary-dark transition-transform" id="bar1"></span>
      <span class="block w-5 h-0.5 bg-primary-dark transition-opacity" id="bar2"></span>
      <span class="block w-5 h-0.5 bg-primary-dark transition-transform" id="bar3"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border/20">
    <div class="max-w-[1312px] mx-auto px-[52px] py-4 flex flex-col gap-4">
      <a href="/about" class="text-sm font-medium text-body">About</a>
      <a href="https://github.com/graphene-data/graphene" target="_blank" rel="noopener" class="text-sm font-medium text-body">GitHub</a>
      <button class="bg-primary-dark text-bg text-sm font-medium rounded-lg px-6 py-2.5 w-fit cursor-pointer">Join waitlist</button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    if (isOpen) {
      bar1!.style.transform = '';
      bar2!.style.opacity = '';
      bar3!.style.transform = '';
    } else {
      bar1!.style.transform = 'rotate(45deg) translate(3px, 3px)';
      bar2!.style.opacity = '0';
      bar3!.style.transform = 'rotate(-45deg) translate(3px, -3px)';
    }
  });
</script>
