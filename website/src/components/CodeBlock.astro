---
import Prism from 'prismjs';
import 'prismjs/components/prism-markdown';
import 'prismjs/components/prism-sql';
import 'prismjs/components/prism-yaml';
import 'prismjs/components/prism-bash';

interface Props {
  label: string;
  code: string;
  class?: string;
  language?: 'markdown' | 'sql' | 'yaml';
}

const { label, code, class: className, language = 'markdown' } = Astro.props;

// Apply syntax highlighting
const highlightedCode = Prism.highlight(code, Prism.languages[language], language);
---

<div class:list={["rounded-xl border border-border-dark bg-code-bg shadow-[0_4px_24px_rgba(0,0,0,0.05)] overflow-hidden", className]}>
  <div class="h-11 flex items-center px-7 border-b border-border-dark shrink-0">
    <span class="font-mono text-xs font-semibold text-code-label">{label}</span>
  </div>
  <div class="px-7 py-5 overflow-y-auto flex-1">
    <pre class="font-mono text-xs font-normal leading-[1.55] whitespace-pre-wrap m-0 language-{language}"><code set:html={highlightedCode}></code></pre>
  </div>
</div>

<style is:global>
  /* Prism.js syntax highlighting theme - customized for Graphene */
  pre code {
    color: #4A4541; /* Default text color */
  }

  /* Comments, prolog, doctype, cdata */
  .token.comment,
  .token.prolog,
  .token.doctype,
  .token.cdata {
    color: #9E9689;
    font-style: italic;
  }

  /* Punctuation */
  .token.punctuation {
    color: #4A4541;
  }

  /* Keywords */
  .token.keyword,
  .token.tag,
  .token.boolean,
  .token.constant,
  .token.symbol,
  .token.deleted {
    color: #9B7EDE; /* Lavender */
  }

  /* Strings, attr-value */
  .token.string,
  .token.char,
  .token.attr-value,
  .token.regex,
  .token.variable {
    color: #5A7A4E; /* Moss green */
  }

  /* Functions, class names */
  .token.operator,
  .token.entity,
  .token.url,
  .token.function,
  .token.class-name {
    color: #7C6F64;
  }

  /* Properties, attributes */
  .token.property,
  .token.attr-name,
  .token.builtin,
  .token.inserted {
    color: #9B7EDE; /* Lavender */
  }

  /* Numbers */
  .token.number {
    color: #7A5FB2; /* Darker lavender for numbers */
  }

  /* Selectors, important */
  .token.selector,
  .token.important,
  .token.atrule {
    color: #9B7EDE; /* Lavender */
    font-weight: 600;
  }

  /* Markdown specific */
  .language-markdown .token.title {
    color: #1B1918;
    font-weight: 600;
  }

  .language-markdown .token.bold {
    font-weight: 600;
  }

  .language-markdown .token.italic {
    font-style: italic;
  }

  .language-markdown .token.code {
    color: #7C6F64;
    background-color: rgba(0, 0, 0, 0.03);
    padding: 0.125em 0.25em;
    border-radius: 0.25em;
  }

  .language-markdown .token.list {
    color: #9B7EDE; /* Lavender */
  }

  .language-markdown .token.hr {
    color: #9E9689;
  }

  .language-markdown .token.url {
    color: #5A7A4E; /* Moss green */
    text-decoration: underline;
  }

  /* SQL specific */
  .language-sql .token.keyword {
    color: #9B7EDE; /* Lavender */
    text-transform: uppercase;
  }

  .language-sql .token.function {
    color: #7C6F64;
  }

  .language-sql .token.operator {
    color: #9B7EDE; /* Lavender */
  }

  .language-sql .token.comment {
    color: #9E9689;
    font-style: italic;
  }
</style>
