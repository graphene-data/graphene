---
import CodeBlock from './CodeBlock.astro';
import dashboardImg from '../assets/dashboard_screenshot.png';

const code = `# Flight Analytics Dashboard

A comprehensive dashboard showcasing flight data metrics from 2000-2005.

## Key Metrics

<Row>
  <BigValue data=flights value=count(*) title="Total Flights" fmt=num0 />
  <BigValue data=flights value=sum(miles_flown) title="Total Miles Flown" fmt=num0m />
  <BigValue data=flights value=on_time_departure_rate title="On-Time Departure Rate" fmt=pct1 />
  <BigValue data=flights value=on_time_arrival_rate title="On-Time Arrival Rate" fmt=pct1 />
</Row>

\`\`\`sql weekly_trends
select
  date_trunc('week', dep_time) as week,
  count(*) as flight_count,
  avg(distance) as avg_distance,
  cancellation_rate
from flights
group by 1
order by 1 asc
\`\`\`
...`;
---

<section class="mt-[150px]">
  <div class="max-w-[1312px] mx-auto px-[52px] flex flex-col gap-12">
    <div class="flex flex-col gap-4 items-center text-center">
      <h2 class="font-serif text-[48px] text-primary-dark tracking-[-1.5px] leading-[1]">Rooted in code</h2>
      <p class="text-lg text-body leading-[1.6] max-w-[600px]">
        Everything is backed by code and CLIs, which agents do best with. Lives in your repo. Open source.
      </p>
      <a href="https://github.com/graphene-data/example-flights" target="_blank" rel="noopener" class="text-base italic font-medium text-muted underline underline-offset-4 hover:text-primary-dark transition-colors">
        See example project →
      </a>
    </div>

    <div class="relative h-[620px] flex items-start justify-center">
      <div class="relative w-[1172px] flex items-center">
        <CodeBlock label="flight-analytics-dashboard.md" code={code} class="relative w-[480px] shrink-0 z-10" />
        <div class="absolute left-[412px] top-1/2 -translate-y-1/2 w-[760px] h-[478px] rounded-xl shadow-[0_4px_24px_rgba(0,0,0,0.05)] overflow-hidden bg-[#F5F5F4] border border-[#E7E5E4] z-20">
          <div class="bg-white h-full overflow-hidden">
            <img src={dashboardImg.src} alt="Flight Analytics Dashboard" class="w-full h-full object-cover object-top" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
