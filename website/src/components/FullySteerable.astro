<style>
  @keyframes progress {
    from { width: 0%; }
    to { width: 100%; }
  }
  .underline-active {
    animation: progress 10s linear forwards;
  }
</style>

<script>
  const tabs = [document.getElementById('tab-0'), document.getElementById('tab-1')];
  const panels = [document.getElementById('carousel-panel-0'), document.getElementById('carousel-panel-1')];
  const underlines = [document.getElementById('underline-0'), document.getElementById('underline-1')];
  let activeTab = 0;
  let timer: ReturnType<typeof setTimeout>;

  function switchTo(index: number) {
    // Update tab text styles
    tabs.forEach((tab, i) => {
      if (i === index) {
        tab!.classList.remove('text-muted');
        tab!.classList.add('text-primary-dark');
      } else {
        tab!.classList.remove('text-primary-dark');
        tab!.classList.add('text-muted');
      }
    });

    // Update panels
    panels.forEach((panel, i) => {
      panel!.classList.toggle('hidden', i !== index);
    });

    // Reset all underlines, animate active one
    underlines.forEach((ul, i) => {
      ul!.classList.remove('underline-active');
      ul!.style.width = '0%';
    });
    // Force reflow to restart animation
    void underlines[index]!.offsetWidth;
    underlines[index]!.classList.add('underline-active');

    activeTab = index;

    clearTimeout(timer);
    timer = setTimeout(() => {
      switchTo((activeTab + 1) % 2);
    }, 10000);
  }

  tabs.forEach((tab, i) => {
    tab!.addEventListener('click', () => switchTo(i));
  });

  // Start auto-cycling
  switchTo(0);
</script>
