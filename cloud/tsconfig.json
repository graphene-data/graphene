{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "moduleDetection": "force", // allow scripts to be treated as modules
  },
  "include": ["**/*.ts", "**/*.js", "**/*.svelte"],
  "exclude": ["node_modules"],
}
