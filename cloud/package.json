{
  "name": "@graphenedata/cloud",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --inspect  server/dev.ts | pino-pretty",
    "build": "vite build --config frontend/vite.config.ts",
    "docker:build": "pnpm build && (cd .. && DOCKER_BUILDKIT=1 docker build -f cloud/server/Dockerfile -t cloud .)",
    "docker:shell": "pnpm docker:build && docker run -it --entrypoint /bin/bash --rm cloud",
    "docker:serve": "pnpm docker:build && docker run -p 3000:3000 --init --rm cloud",
    "db": "sqlite3 cloud.db",
    "studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint . && tsc && svelte-check",
    "test": "vitest run",
    "test-one": "node ../core/scripts/turboTest.js"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.966.0",
    "@ai-sdk/anthropic": "^3.0.8",
    "@fastify/cookie": "^11.0.2",
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^8.3.0",
    "@libsql/client": "^0.15.15",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@stytch/vanilla-js": "^5.38.0",
    "@sveltejs/vite-plugin-svelte": "3.1.2",
    "ai": "^6.0.17",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "glob": "^11.0.3",
    "jsonwebtoken": "^9.0.3",
    "mdsvex": "^0.12.6",
    "modal": "^0.6.0",
    "playwright-core": "^1.57.0",
    "sanitize-html": "^2.17.0",
    "stytch": "^12.42.1",
    "svelte": "4.2.19",
    "ulid": "^2.3.0",
    "unist-util-visit": "4.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.34.0",
    "@playwright/test": "1.54.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.32.0",
    "eslint-plugin-prefer-let": "^4.0.0",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.3.0",
    "pino-pretty": "^13.1.3",
    "playwright": "1.54.2",
    "smee-client": "^5.0.0",
    "svelte-check": "^4.2.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.1.9",
    "vitest": "4.0.15"
  },
  "pnpm": {
    "packageExtensions": {
      "@fastify/cookie": {
        "dependencies": {
          "fastify": "*"
        }
      },
      "@fastify/middie": {
        "dependencies": {
          "fastify": "*"
        }
      }
    }
  }
}
