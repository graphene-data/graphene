{
  "name": "@graphenedata/cloud",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "f() { node --env-file=../.env --inspect server/dev.ts $@ | pino-pretty; }; f",
    "build": "vite build --config frontend/vite.config.ts",
    "docker:build": "pnpm build && (cd .. && DOCKER_BUILDKIT=1 docker build -f cloud/server/Dockerfile -t cloud .)",
    "docker:shell": "pnpm docker:build && docker run -it --entrypoint /bin/bash --rm cloud",
    "docker:serve": "pnpm docker:build && docker run -p 3000:3000 --init --rm cloud",
    "db": "psql $DATABASE_URL",
    "studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "lint": "eslint . && tsc && svelte-check",
    "test": "vitest run",
    "test-one": "node ../core/scripts/turboTest.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.8",
    "@aws-sdk/client-kms": "^3.966.0",
    "@aws-sdk/client-lambda": "^3.966.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/middie": "^9.1.0",
    "@fastify/static": "^9.0.0",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@stytch/vanilla-js": "^5.38.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "ai": "^6.0.69",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "glob": "^13.0.0",
    "jsonwebtoken": "^9.0.3",
    "mdsvex": "^0.12.6",
    "playwright-core": "^1.58.0",
    "postgres": "^3.4.8",
    "sanitize-html": "^2.17.0",
    "stytch": "^13.1.0",
    "svelte": "5.48.0",
    "ulid": "^2.3.0",
    "unist-util-visit": "4.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@aws-sdk/credential-providers": "^3.972.0",
    "@electric-sql/pglite": "^0.3.15",
    "@electric-sql/pglite-socket": "^0.0.20",
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.34.0",
    "@ngrok/ngrok": "^1.7.0",
    "@playwright/test": "^1.58.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-plugin-prefer-let": "^4.0.0",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^16.3.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.0",
    "smee-client": "^5.0.0",
    "svelte-check": "^4.2.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.1.11",
    "vitest": "4.0.15"
  },
  "pnpm": {
    "overrides": {
      "esbuild@~0.18.20": "0.25.11"
    },
    "packageExtensions": {
      "@fastify/cookie": {
        "dependencies": {
          "fastify": "*"
        }
      },
      "@fastify/middie": {
        "dependencies": {
          "fastify": "*"
        }
      }
    }
  }
}
