{
  "permissions": {
    "allow": ["Bash(npm run prepare:*)", "Bash(node:*)"],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm exec zx $CLAUDE_PROJECT_DIR/agent/lint.js"
          }
        ]
      }
    ]
  }
}
