{
  "name": "graphene",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "lint": "oxlint -c oxlint.config.ts --type-check .",
    "test": "vitest run",
    "test-one": "node scripts/turboTest.js",
    "check-examples": "pnpm -C examples/flights graphene check && pnpm -C examples/ecomm graphene check && pnpm -C examples/snowflake graphene check"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.7",
    "dotenv": "^17.2.3",
    "eslint-plugin-prefer-let": "^4.1.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.15",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "fast-xml-parser": ">=5.3.8"
    },
    "ignoredBuiltDependencies": [
      "@sveltejs/kit",
      "keytar"
    ],
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
