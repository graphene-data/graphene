{
  "name": "graphene",
  "private": true,
  "type": "module",
  "workspaces": [
    "lang",
    "cli",
    "vscode",
    "ui"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test-one": "DEBUG=1 node --inspect ./scripts/turboTest.js",
    "watch": "npm run watch --workspace=vscode",
    "agent-setup": "zx scripts/agentSetup.ts",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@malloydata/db-duckdb": "^0.0.304",
    "@malloydata/malloy": "^0.0.302",
    "@types/node": "^22.18.0",
    "eslint": "^9.32.0",
    "eslint-plugin-prefer-let": "^4.0.0",
    "typescript-eslint": "^8.38.0",
    "vitest": "3.0.5",
    "zx": "^8.7.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@types/hast": "*",
        "@types/mdast": "*",
        "vitest": "*",
        "nanoid": "*",
        "unist-util-visit": "*"
      }
    },
    "ignoredBuiltDependencies": [
      "@sveltejs/kit",
      "keytar"
    ],
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "@vscode/vsce-sign",
      "duckdb",
      "esbuild",
      "svelte-preprocess"
    ]
  },
  "dependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.34.0",
    "globals": "^16.3.0"
  }
}
