{
  "name": "graphene",
  "private": true,
  "type": "module",
  "workspaces": [
    "lang",
    "cli",
    "vscode",
    "ui",
    "agent"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test-one": "DEBUG=1 node --inspect ./scripts/turboTest.js",
    "watch": "npm run watch --workspace=vscode",
    "agent-setup": "zx scripts/agentSetup.ts",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@malloydata/db-duckdb": "^0.0.304",
    "@malloydata/malloy": "^0.0.302",
    "@playwright/browser-chromium": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "3.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.18.0",
    "@vitest/browser": "^3.2.4",
    "eslint": "^9.32.0",
    "eslint-plugin-prefer-let": "^4.0.0",
    "playwright": "^1.55.0",
    "svelte": "4.2.19",
    "typescript-eslint": "^8.38.0",
    "vitest": "3.2.4",
    "zx": "^8.7.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@types/hast": "*",
        "@types/mdast": "*",
        "vitest": "*",
        "nanoid": "*",
        "unist-util-visit": "*"
      },
      "ignoreMissing": [
        "@sveltejs/kit"
      ]
    },
    "ignoredBuiltDependencies": [
      "@sveltejs/kit",
      "keytar"
    ],
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "@vscode/vsce-sign",
      "duckdb",
      "esbuild",
      "svelte-preprocess"
    ]
  },
  "dependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/js": "^9.34.0",
    "globals": "^16.3.0"
  }
}
