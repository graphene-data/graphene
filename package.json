{
  "name": "graphene",
  "private": true,
  "type": "module",
  "workspaces": [
    "lang",
    "cli",
    "vscode"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test-one": "DEBUG=1 node --inspect ./scripts/turboTest.js",
    "watch": "npm run watch --workspace=vscode",
    "agent-setup": "zx scripts/agentSetup.ts",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@malloydata/db-duckdb": "^0.0.304",
    "@malloydata/malloy": "^0.0.302",
    "@types/node": "^22.18.0",
    "eslint": "^9.32.0",
    "eslint-plugin-prefer-let": "^4.0.0",
    "typescript-eslint": "^8.38.0",
    "vitest": "3.0.5",
    "zx": "^8.7.2"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.4.2",
      "vitest": "3.0.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "5.4.x || 5.9.x",
        "vitest": "2.x || 3.x"
      }
    },
    "onlyBuiltDependencies": [
      "@sveltejs/kit",
      "@tailwindcss/oxide",
      "@vscode/vsce-sign",
      "duckdb"
    ]
  }
}
