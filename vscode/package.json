{
  "name": "vscode-graphene",
  "displayName": "Graphene VSCode Language Support",
  "publisher": "graphene",
  "description": "",
  "version": "0.0.1",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:graphene-sql"
  ],
  "contributes": {
    "languages": [
      {
        "id": "graphene-sql",
        "aliases": ["Graphene GSQL", "GSQL"],
        "extensions": [".gsql"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "graphene-sql",
        "scopeName": "source.graphene-sql",
        "path": "./gsql.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "node ./esbuild.mjs",
    "vscode:prepublish": "pnpm run build",
    "package": "rm -f -- *.vsix && vsce package --no-dependencies",
    "install-cursor": "pnpm run package && cursor --install-extension *.vsix",
    "install-vscode": "pnpm run package && code --install-extension *.vsix"
  },
  "dependencies": {
    "@graphenedata/lang": "file:../lang",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.21.5"
  }
}
