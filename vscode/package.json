{
  "name": "graphene-data-vscode",
  "displayName": "Graphene VSCode Language Support",
  "version": "0.0.16",
  "private": true,
  "description": "",
  "categories": [
    "Programming Languages"
  ],
  "repository": {},
  "publisher": "graphene-data",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./esbuild.mjs",
    "build:e2e": "node ./tests/e2e/build.mjs",
    "test:e2e": "pnpm run build && pnpm run build:e2e && vscode-test",
    "vscode:prepublish": "pnpm run build",
    "package": "rm -f -- *.vsix && npx vsce package --no-dependencies",
    "publish-extension": "npx vsce publish && npx ovsx publish",
    "install-cursor": "pnpm run package && cursor --install-extension *.vsix",
    "install-vscode": "pnpm run package && code --install-extension *.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "graphene-language-server": "workspace:*",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "graphene-sql",
        "aliases": [
          "Graphene GSQL",
          "GSQL"
        ],
        "extensions": [
          ".gsql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "graphene-sql",
        "scopeName": "source.graphene-sql",
        "path": "./gsql.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:graphene-sql",
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.110.0"
  }
}
