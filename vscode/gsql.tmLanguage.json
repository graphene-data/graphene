{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Graphene SQL",
  "scopeName": "source.graphene-sql",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#quoted-identifiers"},
    {"include": "#numbers"},
    {"include": "#graphene-declarations"},
    {"include": "#types"},
    {"include": "#keywords"},
    {"include": "#functions"},
    {"include": "#operators"},
    {"include": "#member-access"},
    {"include": "#parameters"},
    {"include": "#punctuation"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"include": "#hash-metadata-comment"},
        {"include": "#dash-comment"},
        {
          "name": "comment.block.gsql",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "hash-metadata-comment": {
      "name": "comment.line.number-sign.gsql",
      "begin": "#",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.comment.gsql"}
      },
      "end": "$",
      "patterns": [{"include": "#metadata-first-pair"}, {"include": "#metadata-pair"}]
    },
    "dash-comment": {
      "name": "comment.line.double-dash.gsql",
      "begin": "--",
      "beginCaptures": {
        "0": {"name": "punctuation.definition.comment.gsql"}
      },
      "end": "$",
      "patterns": [{"include": "#metadata-pair"}]
    },
    "metadata-first-pair": {
      "patterns": [
        {
          "name": "meta.metadata-pair.gsql",
          "match": "\\s*([A-Za-z0-9_-]+)(\\s*=\\s*)(\"(?:\\\\.|[^\"])*\"|[^\\s#]+)",
          "captures": {
            "1": {"name": "entity.other.attribute-name.metadata.gsql"},
            "2": {"name": "keyword.operator.assignment.metadata.gsql"},
            "3": {"name": "string.other.metadata.gsql"}
          }
        }
      ]
    },
    "metadata-pair": {
      "patterns": [
        {
          "name": "meta.metadata-pair.gsql",
          "match": "(#)(\\s*)([A-Za-z0-9_-]+)(\\s*=\\s*)(\"(?:\\\\.|[^\"])*\"|[^\\s#]+)",
          "captures": {
            "1": {"name": "punctuation.definition.metadata.gsql"},
            "3": {"name": "entity.other.attribute-name.metadata.gsql"},
            "4": {"name": "keyword.operator.assignment.metadata.gsql"},
            "5": {"name": "string.other.metadata.gsql"}
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.gsql",
          "begin": "'",
          "end": "'",
          "patterns": [{"name": "constant.character.escape.gsql", "match": "''"}]
        },
        {
          "name": "string.quoted.backtick.gsql",
          "begin": "`",
          "end": "`",
          "patterns": [{"name": "constant.character.escape.gsql", "match": "``"}]
        }
      ]
    },
    "quoted-identifiers": {
      "patterns": [
        {
          "name": "string.quoted.double.identifier.gsql",
          "begin": "\"",
          "end": "\"",
          "patterns": [{"name": "constant.character.escape.gsql", "match": "\"\""}]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.gsql",
          "match": "(?i)\\b((0x[0-9a-f]+)|(\\d+\\.?\\d*|\\.\\d+)(e[+-]?\\d+)?)\\b"
        }
      ]
    },
    "graphene-declarations": {
      "patterns": [
        {
          "name": "meta.declaration.table.graphene.gsql",
          "begin": "(?i)\\btable\\s+([A-Za-z_][A-Za-z0-9_$]*)\\s*\\(",
          "beginCaptures": {
            "0": {"name": "keyword.declaration.table.gsql"},
            "1": {"name": "entity.name.table.gsql"}
          },
          "end": "\\)",
          "patterns": [
            {"include": "#comments"},
            {"include": "#strings"},
            {"include": "#quoted-identifiers"},
            {
              "match": "([A-Za-z_][A-Za-z0-9_$]*)\\s*:(?!:)",
              "captures": {
                "1": {"name": "entity.name.tag.graphene.gsql"}
              }
            },
            {"include": "#types"},
            {"include": "#keywords"},
            {"include": "#functions"},
            {"include": "#operators"}
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gsql",
          "match": "(?i)\\b(SELECT|FROM|WHERE|GROUP|BY|HAVING|ORDER|LIMIT|OFFSET|INSERT|INTO|VALUES|UPDATE|SET|DELETE|CREATE|ALTER|DROP|TRUNCATE|REPLACE|VIEW|TABLE|INDEX|PRIMARY|KEY|FOREIGN|REFERENCES|CONSTRAINT|UNIQUE|NOT|NULL|DEFAULT|CHECK|AND|OR|XOR|CASE|WHEN|THEN|ELSE|END|AS|ON|JOIN\\s+ONE|JOIN\\s+MANY|JOIN|INNER|LEFT|RIGHT|FULL|OUTER|CROSS|UNNEST|NATURAL|USING|DISTINCT|ALL|UNION|EXCEPT|INTERSECT|WITH|RECURSIVE|OVER|PARTITION|RANGE|ROWS|BETWEEN|UNBOUNDED|PRECEDING|FOLLOWING|CURRENT|ROW|LIKE|ILIKE|SIMILAR|IN|IS|TRUE|FALSE|UNKNOWN|ESCAPE|ROLLUP|CUBE|FILTER|WITHIN|GROUP|QUALIFY|TOP)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "meta.type.array.gsql",
          "begin": "(?i)\\b(array)\\b\\s*<",
          "beginCaptures": {
            "1": {"name": "storage.type.gsql"}
          },
          "end": ">",
          "patterns": [
            {"include": "#comments"},
            {"include": "#strings"},
            {"include": "#quoted-identifiers"},
            {"include": "#types"},
            {"include": "#keywords"},
            {"include": "#operators"},
            {"include": "#punctuation"}
          ]
        },
        {
          "name": "storage.type.gsql",
          "begin": "(?i)\\b(DOUBLE\\s+PRECISION|CHAR\\s+VARYING|VARCHAR|CHAR|NCHAR|NVARCHAR|DECIMAL|NUMERIC|NUMBER)\\b\\s*\\(",
          "beginCaptures": {
            "1": {"name": "storage.type.gsql"}
          },
          "end": "\\)",
          "patterns": [
            {"include": "#comments"},
            {"include": "#strings"},
            {"include": "#quoted-identifiers"},
            {"include": "#numbers"},
            {"include": "#functions"},
            {"include": "#operators"},
            {"include": "#punctuation"}
          ]
        },
        {
          "name": "storage.type.gsql",
          "match": "(?i)\\b(DOUBLE\\s+PRECISION|CHAR\\s+VARYING|VARCHAR|CHAR|NCHAR|NVARCHAR|DECIMAL|NUMERIC|NUMBER)\\b"
        },
        {
          "name": "storage.type.gsql",
          "match": "(?i)\\b(INT|INTEGER|SMALLINT|BIGINT|TINYINT|FLOAT|DOUBLE|REAL|BOOLEAN|BOOL|DATE|TIME|TIMESTAMP|TIMESTAMP_NTZ|TIMESTAMP_TZ|TIMESTAMP_LTZ|TIMESTAMPTZ|TEXT|BLOB|JSON|UUID|SERIAL|BIGSERIAL|MONEY|STRING|NUMBER|VARBINARY|BINARY|INTERVAL)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function-call.aggregate.gsql",
          "begin": "(?i)\\b(COUNT|SUM|AVG|MIN|MAX|ARRAY_AGG|STRING_AGG)\\b\\s*\\(",
          "beginCaptures": {
            "1": {"name": "support.function.aggregate.gsql"}
          },
          "end": "\\)",
          "patterns": [
            {"include": "#comments"},
            {"include": "#strings"},
            {"include": "#quoted-identifiers"},
            {"include": "#numbers"},
            {"include": "#types"},
            {"include": "#keywords"},
            {"include": "#functions"},
            {"include": "#operators"},
            {"include": "#member-access"},
            {"include": "#parameters"},
            {"include": "#punctuation"}
          ]
        },
        {
          "name": "meta.function-call.scalar.gsql",
          "begin": "(?i)\\b(COALESCE|NULLIF|IFNULL|GREATEST|LEAST|ABS|ROUND|CEIL|CEILING|FLOOR|POWER|EXP|LN|LOG|LOG10|SQRT|MOD|SUBSTR|SUBSTRING|LEFT|RIGHT|POSITION|CHAR_LENGTH|CHARACTER_LENGTH|LENGTH|LOWER|UPPER|INITCAP|TRIM|RTRIM|LTRIM|TO_CHAR|TO_DATE|TO_TIMESTAMP|NOW|CURRENT_DATE|CURRENT_TIME|CURRENT_TIMESTAMP)\\b\\s*\\(",
          "beginCaptures": {
            "1": {"name": "support.function.scalar.gsql"}
          },
          "end": "\\)",
          "patterns": [
            {"include": "#comments"},
            {"include": "#strings"},
            {"include": "#quoted-identifiers"},
            {"include": "#numbers"},
            {"include": "#types"},
            {"include": "#keywords"},
            {"include": "#functions"},
            {"include": "#operators"},
            {"include": "#member-access"},
            {"include": "#parameters"},
            {"include": "#punctuation"}
          ]
        },
        {
          "name": "meta.function-call.gsql",
          "begin": "(?i)\\b([A-Za-z_][A-Za-z0-9_$]*)\\b\\s*\\(",
          "beginCaptures": {
            "1": {"name": "entity.name.function.gsql"}
          },
          "end": "\\)",
          "patterns": [
            {"include": "#comments"},
            {"include": "#strings"},
            {"include": "#quoted-identifiers"},
            {"include": "#numbers"},
            {"include": "#types"},
            {"include": "#keywords"},
            {"include": "#functions"},
            {"include": "#operators"},
            {"include": "#member-access"},
            {"include": "#parameters"},
            {"include": "#punctuation"}
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {"name": "keyword.operator.arithmetic.gsql", "match": "[+\\-*/%]"},
        {"name": "keyword.operator.comparison.gsql", "match": "=|<>|!=|<=|>=|<|>"},
        {"name": "keyword.operator.logical.gsql", "match": "(?i)\\b(NOT|AND|OR|XOR)\\b|\\|\\||&&|!"},
        {"name": "keyword.operator.concatenation.gsql", "match": "\\|\\|"}
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.gsql",
          "match": "\\b[A-Za-z_][A-Za-z0-9_$]*(?:\\.[A-Za-z_][A-Za-z0-9_$]*)+\\b"
        }
      ]
    },
    "parameters": {
      "patterns": [
        {"name": "variable.parameter.gsql", "match": ":[A-Za-z_][A-Za-z0-9_]*"},
        {"name": "variable.parameter.gsql", "match": "@[_A-Za-z][_A-Za-z0-9]*"},
        {"name": "variable.parameter.positional.gsql", "match": "\\?"}
      ]
    },
    "punctuation": {
      "patterns": [
        {"name": "punctuation.separator.comma.gsql", "match": ","},
        {"name": "punctuation.terminator.statement.gsql", "match": ";"},
        {"name": "punctuation.section.parens.begin.gsql", "match": "\\("},
        {"name": "punctuation.section.parens.end.gsql", "match": "\\)"}
      ]
    }
  }
}
