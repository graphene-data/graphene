{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Graphene SQL",
  "scopeName": "source.gsql",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#quoted-identifiers" },
    { "include": "#numbers" },
    { "include": "#graphene-declarations" },
    { "include": "#types" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#member-access" },
    { "include": "#parameters" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.gsql",
          "match": "--.*$"
        },
        {
          "name": "comment.block.gsql",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.number-sign.gsql",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.gsql",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.gsql", "match": "''" }
          ]
        },
        {
          "name": "string.quoted.backtick.gsql",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "name": "constant.character.escape.gsql", "match": "``" }
          ]
        }
      ]
    },
    "quoted-identifiers": {
      "patterns": [
        {
          "name": "string.quoted.double.identifier.gsql",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.gsql", "match": "\"\"" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.gsql",
          "match": "(?i)\\b((0x[0-9a-f]+)|(\\d+\\.?\\d*|\\.\\d+)(e[+-]?\\d+)?)\\b"
        }
      ]
    },
    "graphene-declarations": {
      "patterns": [
        {
          "name": "meta.declaration.table.graphene.gsql",
          "begin": "(?i)\\btable\\s+([A-Za-z_][A-Za-z0-9_$]*)\\s*\\(",
          "beginCaptures": {
            "0": { "name": "keyword.declaration.table.gsql" },
            "1": { "name": "entity.name.table.gsql" }
          },
          "end": "\\)",
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#quoted-identifiers" },
            { "include": "#types" },
            { "include": "#keywords" },
            { "include": "#functions" },
            { "include": "#operators" },
            {
              "name": "meta.graphene.measure.entry.gsql",
              "match": "(?i)\\bmeasure\\s+([A-Za-z_][A-Za-z0-9_$]*)",
              "captures": {
                "0": { "name": "keyword.other.measure.graphene.gsql" },
                "1": { "name": "entity.name.measure.graphene.gsql" }
              }
            },
            {
              "name": "meta.graphene.join-one.entry.gsql",
              "match": "(?i)\\bjoin_(one|many)\\s+([A-Za-z_][A-Za-z0-9_$]*)",
              "captures": {
                "0": { "name": "keyword.other.join.graphene.gsql" },
                "1": { "name": "storage.modifier.join-kind.graphene.gsql" },
                "2": { "name": "entity.name.table.gsql" }
              }
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gsql",
          "match": "(?i)\\b(SELECT|FROM|WHERE|GROUP|BY|HAVING|ORDER|LIMIT|OFFSET|INSERT|INTO|VALUES|UPDATE|SET|DELETE|CREATE|ALTER|DROP|TRUNCATE|REPLACE|VIEW|TABLE|INDEX|PRIMARY|KEY|FOREIGN|REFERENCES|CONSTRAINT|UNIQUE|NOT|NULL|DEFAULT|CHECK|AND|OR|XOR|CASE|WHEN|THEN|ELSE|END|AS|ON|JOIN|INNER|LEFT|RIGHT|FULL|OUTER|CROSS|NATURAL|USING|DISTINCT|ALL|UNION|EXCEPT|INTERSECT|WITH|RECURSIVE|OVER|PARTITION|RANGE|ROWS|BETWEEN|UNBOUNDED|PRECEDING|FOLLOWING|CURRENT|ROW|LIKE|ILIKE|SIMILAR|IN|IS|TRUE|FALSE|UNKNOWN|ESCAPE|ROLLUP|CUBE|FILTER|WITHIN|GROUP|QUALIFY|TOP)\\b"
        },
        {
          "name": "keyword.other.graphene.gsql",
          "match": "(?i)\\b(join_one|join_many|measure)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.gsql",
          "match": "(?i)\\b(DOUBLE\\s+PRECISION|CHAR\\s+VARYING)\\b"
        },
        {
          "name": "storage.type.gsql",
          "match": "(?i)\\b(VARCHAR|CHAR|NCHAR|NVARCHAR|DECIMAL|NUMERIC|NUMBER)\\b"
        },
        {
          "name": "storage.type.gsql",
          "match": "(?i)\\b(VARCHAR|CHAR|NCHAR|NVARCHAR|DECIMAL|NUMERIC|NUMBER)\\b\\s*\\(\\s*\\d+(?:\\s*,\\s*\\d+)?\\s*\\)"
        },
        {
          "name": "storage.type.gsql",
          "match": "(?i)\\b(INT|INTEGER|SMALLINT|BIGINT|TINYINT|FLOAT|DOUBLE|REAL|BOOLEAN|BOOL|DATE|TIME|TIMESTAMP|TIMESTAMPTZ|TEXT|BLOB|JSON|UUID|SERIAL|BIGSERIAL|MONEY|STRING|NUMBER|VARBINARY|BINARY)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.aggregate.gsql",
          "match": "(?i)\\b(COUNT|SUM|AVG|MIN|MAX|ARRAY_AGG|STRING_AGG)\\s*\\("
        },
        {
          "name": "support.function.scalar.gsql",
          "match": "(?i)\\b(COALESCE|NULLIF|IFNULL|GREATEST|LEAST|ABS|ROUND|CEIL|CEILING|FLOOR|POWER|EXP|LN|LOG|LOG10|SQRT|MOD|SUBSTR|SUBSTRING|LEFT|RIGHT|POSITION|CHAR_LENGTH|CHARACTER_LENGTH|LENGTH|LOWER|UPPER|INITCAP|TRIM|RTRIM|LTRIM|TO_CHAR|TO_DATE|TO_TIMESTAMP|NOW|CURRENT_DATE|CURRENT_TIME|CURRENT_TIMESTAMP)\\s*\\("
        },
        {
          "name": "entity.name.function.gsql",
          "match": "(?i)\\b([A-Za-z_][A-Za-z0-9_$]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.gsql" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arithmetic.gsql", "match": "[+\\-*/%]" },
        { "name": "keyword.operator.comparison.gsql", "match": "=|<>|!=|<=|>=|<|>" },
        { "name": "keyword.operator.logical.gsql", "match": "(?i)\\b(NOT|AND|OR|XOR)\\b|\\|\\||&&|!" },
        { "name": "keyword.operator.concatenation.gsql", "match": "\\|\\|" }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.gsql",
          "match": "\\b[A-Za-z_][A-Za-z0-9_$]*(?:\\.[A-Za-z_][A-Za-z0-9_$]*)+\\b"
        }
      ]
    },
    "parameters": {
      "patterns": [
        { "name": "variable.parameter.gsql", "match": ":[A-Za-z_][A-Za-z0-9_]*" },
        { "name": "variable.parameter.gsql", "match": "@[_A-Za-z][_A-Za-z0-9]*" },
        { "name": "variable.parameter.positional.gsql", "match": "\\?" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.separator.comma.gsql", "match": "," },
        { "name": "punctuation.terminator.statement.gsql", "match": ";" },
        { "name": "punctuation.section.parens.begin.gsql", "match": "\\(" },
        { "name": "punctuation.section.parens.end.gsql", "match": "\\)" }
      ]
    }
  }
}
