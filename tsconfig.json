{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noImplicitAny": false,
    "types": ["node"]
  },
  "include": ["**/*.ts", "**/*.js", "**/*.svelte"],
  "exclude": ["node_modules", "cli/dist", "vscode/dist"]
}
