table entities (
  entity_id TEXT -- Brizo entity ID
  score NUMBER -- Percentage score of matched ingredient (score can be 100 for extracted items and maximum of 99 for predicted)
  category TEXT
  menu_item_id TEXT
  name TEXT
  subcategory TEXT
  type TEXT
  matches VARIANT -- Matched entity tag
  variant VARIANT

  join one menu_items on menu_item_id = menu_items.menu_item_id
)
