-- Each row represents a video upload by a user (links users to their uploaded videos).
table user_upload (
  id INT64 primary_key -- Unique identifier for the upload record
  user_id INT64 -- ID of the user who uploaded the video
  video_id INT64 -- ID of the uploaded video

  join one user on user_id = user.id
  join one video on video_id = video.id
)
