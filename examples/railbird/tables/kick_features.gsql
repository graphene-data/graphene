-- Each row contains features for a kick shot (shot where the cue ball hits a rail before hitting the object ball).
table kick_features (
  shot_id INT64 primary_key -- ID of the shot
  walls_hit STRING -- Array of walls hit by the cue ball (long rail or short rail)
  angle FLOAT64 -- Angle of the kick shot in degrees
  distance FLOAT64 -- Distance traveled by the cue ball before hitting the object ball

  join one shot on shot_id = shot.id
)
