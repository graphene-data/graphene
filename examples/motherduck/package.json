{
  "name": "motherduck-example",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "graphene": "node ../../cli/cli.ts",
    "serve": "graphene serve",
    "compile": "graphene compile",
    "run": "graphene run"
  },
  "dependencies": {
    "@duckdb/node-api": "1.3.2-alpha.26",
    "@graphenedata/cli": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "graphene": {
    "motherduck": {
      "database": "sample_data"
    },
    "defaultNamespace": "sample_data.who",
    "envFile": [
      ".env",
      "../../.env",
      "../../../.env"
    ]
  }
}
