{
  "name": "ecomm-example",
  "version": "0.0.1",
  "scripts": {
    "setup": "gcloud init --project=intense-acumen-470417-u5",
    "cli": "node ../../cli/cli.ts",
    "serve": "npm run cli serve",
    "compile": "npm run cli compile",
    "run": "npm run cli run",
    "build": "evidence build",
    "build:strict": "evidence build:strict",
    "dev": "evidence dev --open /",
    "test": "evidence build",
    "sources": "evidence sources",
    "sources:strict": "evidence sources --strict",
    "preview": "evidence preview"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "dependencies": {
    "@evidence-dev/core-components": "^5.2.2",
    "@evidence-dev/evidence": "^40.1.2",
    "@graphene/cli": "workspace:*",
    "@graphene/ui": "workspace:*",
    "svelte": "4.2.19"
  },
  "graphene": {
    "dialect": "bigquery",
    "namespace": "bigquery-public-data.thelook_ecommerce"
  }
}
