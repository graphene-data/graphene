{
  "name": "clickhouse-example",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "graphene": "node ../../cli/cli.ts",
    "dev": "npm run graphene serve",
    "compile": "npm run graphene compile",
    "run": "npm run graphene run",
    "serve": "npm run dev"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "@graphenedata/cli": "workspace:*",
    "svelte": "5.53.7"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "graphene": {
    "dialect": "clickhouse",
    "defaultNamespace": "default",
    "clickhouse": {
      "url": "http://ec2-3-217-185-14.compute-1.amazonaws.com:8123",
      "username": "graphene"
    },
    "envFile": [
      ".env",
      "../../.env",
      "../../../.env"
    ]
  }
}
